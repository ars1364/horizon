# Copy this file to .env and fill in your values.
# .env is gitignored — never commit the real file.

# ── OpenStack cluster ─────────────────────────────────────────────────────────
# IP or hostname of the controller node (used for API routing)
OPENSTACK_HOST=192.168.204.10

# Keystone v3 endpoint reachable from the Horizon container
OPENSTACK_KEYSTONE_URL=http://192.168.204.10:5000/v3

# Which endpoint type Horizon uses when calling OpenStack APIs
# internalURL is correct when the container is on the same network as the cluster
OPENSTACK_ENDPOINT_TYPE=internalURL

OPENSTACK_DEFAULT_DOMAIN=Default
OPENSTACK_DEFAULT_ROLE=member

# ── Horizon ───────────────────────────────────────────────────────────────────
# Set to false in production
DEBUG=false

# Comma-separated list of hostnames/IPs the server is reachable at.
# Use * only for development.
ALLOWED_HOSTS=horizon.example.com,192.168.204.x

# Leave blank to auto-generate a persistent key stored in the Docker volume.
# For production, generate once with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# and set it here so it survives container rebuilds.
DJANGO_SECRET_KEY=

# Theme to load by default (cat-dark | default | material)
HORIZON_DEFAULT_THEME=cat-dark

TIME_ZONE=UTC
